#!/usr/bin/env python3

import argparse
import subprocess
import sys
import os
import shutil
import re

ANSIBLE_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "ansible")
INVENTORY = os.path.join(ANSIBLE_DIR, "inventory/hosts.ini")
PLAYBOOKS = os.path.join(ANSIBLE_DIR, "playbooks")
SSH_KEY = os.path.expanduser("~/.ssh/id_rsa")

def check_prerequisites():
    print("Checking prerequisites...")
    ok = True

    # Check container runtime (prefer Podman)
    if shutil.which("podman"):
        r = subprocess.run(["podman", "--version"], capture_output=True, text=True)
        print(f"  ✓ {r.stdout.strip()} found")
    elif shutil.which("docker"):
        r = subprocess.run(["docker", "--version"], capture_output=True, text=True)
        print(f"  ✓ {r.stdout.strip()} found")
    else:
        print("  ✗ Container runtime not found (Docker or Podman)")
        print("    Install Podman: https://podman.io/docs/installation")
        print("    Install Docker: https://docs.docker.com/engine/install/")
        ok = False

    # Check Ansible 2.14+
    if shutil.which("ansible-playbook"):
        r = subprocess.run(["ansible-playbook", "--version"], capture_output=True, text=True)
        version_line = r.stdout.split("\n")[0]
        match = re.search(r'(\d+)\.(\d+)', version_line)
        if match:
            major, minor = int(match.group(1)), int(match.group(2))
            if (major, minor) < (2, 14):
                print(f"  ✗ {version_line} found — version 2.14+ is required")
                print("    Upgrade: pip install --upgrade ansible")
                ok = False
            else:
                print(f"  ✓ {version_line} found")
        else:
            print(f"  ✓ {version_line} found")
    else:
        print("  ✗ Ansible not found")
        print("    Install: pip install ansible (or use your OS package manager)")
        ok = False

    if not ok:
        print("\nPlease install the missing dependencies and retry.")
        sys.exit(1)

    print("  Proceeding...\n")

def run_playbook(playbook, extra_vars=None, quiet=False):
    cmd = [
        "ansible-playbook",
        "-i", INVENTORY,
        os.path.join(PLAYBOOKS, playbook),
        "--private-key", SSH_KEY,
        "-u", "root"
    ]
    if extra_vars:
        for k, v in extra_vars.items():
            cmd += ["-e", f"{k}={v}"]
    
    env = os.environ.copy()
    env["ANSIBLE_CONFIG"] = os.path.join(ANSIBLE_DIR, "ansible.cfg")
    
    if quiet:
        result = subprocess.run(cmd, env=env, capture_output=True, text=True)
    else:
        result = subprocess.run(cmd, env=env)
        
    if result.returncode != 0:
        print(f"\n[ERROR] Playbook {playbook} failed!")
        if quiet:
            print(result.stderr or result.stdout)
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(prog="redis-tool",
        description="Redis Cluster Lifecycle Tool — provision, operate, and upgrade a Redis Cluster via Ansible")
    subparsers = parser.add_subparsers(dest="command")

    # provision
    p = subparsers.add_parser("provision", help="Provision a Redis Cluster")
    p.add_argument("--version", required=True, help="Redis version to install (e.g. 7.0.15)")
    p.add_argument("--masters", type=int, default=3, help="Number of master nodes")
    p.add_argument("--replicas-per-master", type=int, default=1, help="Replicas per master")

    # status
    subparsers.add_parser("status", help="Show cluster status")

    # data seed / data verify
    data = subparsers.add_parser("data", help="Data operations (seed/verify)")
    data_sub = data.add_subparsers(dest="data_command")
    seed = data_sub.add_parser("seed", help="Seed keys into the cluster")
    seed.add_argument("--keys", type=int, default=1000, help="Number of keys to seed")
    data_sub.add_parser("verify", help="Verify seeded keys")

    # upgrade
    u = subparsers.add_parser("upgrade", help="Rolling upgrade")
    u.add_argument("--target-version", required=True, help="Target Redis version (e.g. 7.2.6)")
    u.add_argument("--strategy", default="rolling", choices=["rolling"], help="Upgrade strategy")

    # verify --full
    v = subparsers.add_parser("verify", help="Full verification")
    v.add_argument("--full", action="store_true", help="Run comprehensive verification")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    # Run prerequisite check before every command
    check_prerequisites()

    if args.command == "provision":
        print(f"Provisioning Redis Cluster v{args.version}...")
        run_playbook("provision.yml", {
            "redis_version": args.version,
            "redis_masters": args.masters,
            "redis_replicas_per_master": args.replicas_per_master,
        })
    elif args.command == "status":
        print("Fetching cluster status...\n")
        run_playbook("fix_replicas.yml")
        run_playbook("status.yml")
    elif args.command == "data":
        if args.data_command == "seed":
            print(f"Seeding {args.keys} keys...")
            run_playbook("seed.yml", {"key_count": args.keys})
        elif args.data_command == "verify":
            print("Verifying data...")
            run_playbook("verify.yml")
        else:
            print("Usage: redis-tool data {seed|verify}")
            sys.exit(1)
    elif args.command == "upgrade":
        print(f"Upgrading to v{args.target_version} ({args.strategy})...")
        run_playbook("upgrade.yml", {"target_version": args.target_version})
    elif args.command == "verify":
        print("Running full verification...")
        run_playbook("full_verify.yml")

if __name__ == "__main__":
    main()
